# AWS Credentials
YOUR_AWS_ACCESS_KEY_ID=your_access_key_here
YOUR_AWS_SECRET_ACCESS_KEY=your_secret_key_here
YOUR_AWS_REGION=us-east-1

# Email Configuration
SES_SENDER_EMAIL=noreply@yourdomain.com

# Application URLs
FRONTEND_URL=http://localhost:3000
REACT_APP_BASE_URL=http://localhost:8000/api/v1

# Database
DYNAMODB_TABLE_NAME=cloud-health-dashboard

# ECR (for CI/CD)
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_FRONTEND_REPO=cloud-health-frontend
ECR_BACKEND_REPO=cloud-health-backend
ECR_NGINX_REPO=cloud-health-nginx
